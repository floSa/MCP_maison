# Le petit LLM utilisé par l'agent.
# Autres choix possibles : qwen2.5:1.5b (plus petit), qwen2.5:3b, phi4-mini.
MODELE=gemma4:e4b

# Dossier hôte partagé entre projets pour les modèles Ollama (évite de
# retélécharger le même modèle dans chaque projet). Commentez pour utiliser
# un volume Docker local au projet.
OLLAMA_MODELES=/home/florian/mes_projets/feedbacks-projet/.ollama
